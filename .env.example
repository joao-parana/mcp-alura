# =============================================================
# MCP Server — AutoPeças & Leitos Hospitalares
# =============================================================
# Copie este arquivo para .env e preencha as variáveis

# --- Google Sheets (planilha compartilhada) ---
# ID encontrado na URL: docs.google.com/spreadsheets/d/<SPREADSHEET_ID>/edit
SPREADSHEET_ID=1zt4h2v3ldK3zELNNmvyn02elEB9dHdfXD5q85ZYh2k0

# --- Autenticação Google ---
# IMPORTANTE: a Service Account precisa de permissão EDITOR na planilha
# (não apenas Leitor), pois leitos_atualizar_status_limpeza escreve na aba Leitos.
#
# Opção 1: caminho para o arquivo JSON da Service Account (recomendado)
GOOGLE_CREDENTIALS_PATH=/caminho/para/service_account.json
#
# Opção 2: conteúdo JSON da Service Account como variável de ambiente
# GOOGLE_CREDENTIALS_JSON={"type":"service_account","project_id":"..."}

# =============================================================
# AutoPeças — aba "AutoPeças" (gid=0)
# =============================================================

AUTOPECAS_SHEET_NAME=AutoPeças

# Mapeamento de colunas (altere apenas se os cabeçalhos diferirem)
# COL_CODIGO=Código
# COL_NOME=Nome
# COL_CATEGORIA=Categoria
# COL_MARCA=Marca
# COL_PRECO=Preço
# COL_ESTOQUE=Estoque
# COL_FORNECEDOR=Fornecedor
# COL_DESCRICAO=Descrição
# COL_LOCALIZACAO=Localização

# =============================================================
# Leitos Hospitalares — aba "Leitos" (gid=1562350974)
# =============================================================

LEITOS_SHEET_NAME=Leitos

# Colunas confirmadas pelo schema do nó "Atualizar Base de Dados Hospital"
# LEITOS_COL_LEITO=ID_Leito
# LEITOS_COL_QUARTO=Quarto
# LEITOS_COL_TIPO_QUARTO=Tipo_Quarto
# LEITOS_COL_STATUS_OCUPACAO=Status_Ocupacao
# LEITOS_COL_STATUS_LIMPEZA=Status_Limpeza
# LEITOS_COL_PACIENTE=Paciente
# LEITOS_COL_ULTIMA_LIMPEZA=Ultima_Limpeza

# Colunas opcionais (podem existir na planilha real)
# LEITOS_COL_DATA_INTERNACAO=Data_Internacao
# LEITOS_COL_PREVISAO_ALTA=Previsao_Alta
# LEITOS_COL_MEDICO=Medico
# LEITOS_COL_OBSERVACOES=Observacoes

# =============================================================
# Gmail SMTP — leitos_enviar_notificacao
# =============================================================

GMAIL_USER=setor@hospital.com.br
# Senha de App (não é a senha comum): myaccount.google.com/apppasswords
GMAIL_APP_PASSWORD=xxxx_xxxx_xxxx_xxxx

# =============================================================
# Twilio SMS — leitos_enviar_sms
# =============================================================

TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Número remetente registrado no Twilio (formato E.164)
TWILIO_FROM_NUMBER=+18647139932
