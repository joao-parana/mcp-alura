# =============================================================
# MCP AutoPeças - Configuração
# =============================================================
# Copie este arquivo para .env e preencha as variáveis

# --- Google Sheets ---
# ID da planilha (encontrado na URL: docs.google.com/spreadsheets/d/<SPREADSHEET_ID>/edit)
SPREADSHEET_ID=seu_spreadsheet_id_aqui

# Nome da aba (worksheet) que contém os dados de autopeças
SHEET_NAME=AutoPeças

# --- Autenticação Google ---
# Opção 1: caminho para o arquivo JSON da Service Account
GOOGLE_CREDENTIALS_PATH=/caminho/para/service_account.json

# Opção 2: conteúdo JSON da Service Account como variável de ambiente (base64 ou JSON inline)
# GOOGLE_CREDENTIALS_JSON={"type":"service_account","project_id":"..."}

# --- Mapeamento de Colunas (opcional) ---
# Nomes das colunas na planilha (padrão já configurado, altere se necessário)
# COL_CODIGO=Código
# COL_NOME=Nome
# COL_CATEGORIA=Categoria
# COL_MARCA=Marca
# COL_PRECO=Preço
# COL_ESTOQUE=Estoque
# COL_FORNECEDOR=Fornecedor
# COL_DESCRICAO=Descrição
# COL_LOCALIZACAO=Localização
